   "source": [
    "# 04 — Fallback Strategies: Examples\n",
    "\n",
    "> Build a resilient router with retry logic, circuit breakers, and fallback chains.\n",
    "\n",
    "---\n",
    "\n",
    "**What you'll build:**\n",
    "1. Error classifier (retryable vs. failover vs. fatal)\n",
    "2. Retry with exponential backoff\n",
    "3. Linear fallback chain\n",
    "4. Circuit breaker pattern\n",
    "5. Full FallbackRouter with all strategies combined\n",
    "6. Cache fallback as last resort"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# !pip install openai tenacity python-dotenv rich"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, time, random, hashlib, json\n",
    "from dataclasses import dataclass, field\n",
    "from datetime import datetime, timedelta\n",
    "from enum import Enum\n",
    "from typing import Callable\n",
    "from openai import OpenAI, RateLimitError, APIStatusError, APITimeoutError\n",
    "from dotenv import load_dotenv\n",
    "from rich import print as rprint\n",
    "from rich.table import Table\n",
    "from rich.console import Console\n",
    "\n",
    "load_dotenv()\n",
    "client = OpenAI()\n",
    "console = Console()\n",
    "print('✅ Setup complete')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Part 1: Error Classification"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ErrorClass(Enum):\n",
    "    RETRYABLE = \"retryable\"   # Wait + retry same model\n",
    "    FAILOVER  = \"failover\"    # Switch to next model in chain\n",
    "    FATAL     = \"fatal\"       # Don't retry, surface error immediately\n",
    "\n",
    "\n",
    "def classify_error(error: Exception) -> ErrorClass:\n",
    "    \"\"\"Classify an API error to determine the recovery strategy.\"\"\"\n",
    "    code = getattr(error, \"status_code\", None)\n",
    "    msg  = str(error).lower()\n",
    "\n",
    "    if isinstance(error, RateLimitError) or code == 429:\n",
    "        return ErrorClass.RETRYABLE\n",
    "\n",
    "    if code in {500, 502, 503, 504}:\n",
    "        return ErrorClass.FAILOVER\n",
    "\n",
    "    if isinstance(error, APITimeoutError) or \"timeout\" in msg:\n",
    "        return ErrorClass.FAILOVER\n",
    "\n",
    "    if \"context\" in msg and (\"length\" in msg or \"limit\" in msg or \"exceed\" in msg):\n",
    "        return ErrorClass.FAILOVER\n",
    "\n",
    "    if \"content\" in msg and \"filter\" in msg:\n",
    "        return ErrorClass.FAILOVER\n",
    "\n",
    "    if code in {400, 401, 403}:\n",
    "        return ErrorClass.FATAL\n",
    "\n",
    "    return ErrorClass.FAILOVER  # Unknown → try failover\n",
    "\n",
    "\n",
    "# ── Demonstrate error classification ──────────────────────────────────────\n",
    "\n",
    "# Create mock exceptions to demonstrate classification\n",
    "class MockAPIError(Exception):\n",
    "    def __init__(self, message, status_code=None):\n",
    "        super().__init__(message)\n",
    "        self.status_code = status_code\n",
    "\n",
    "mock_errors = [\n",
    "    (RateLimitError(\"Rate limit exceeded\", response=None, body=None), \"Rate limit 429\"),\n",
    "    (MockAPIError(\"Internal server error\", 500), \"Server error 500\"),\n",
    "    (MockAPIError(\"Context length exceeded: 130k > 128k limit\"), \"Context exceeded\"),\n",
    "    (MockAPIError(\"Content filter triggered\"), \"Content filter\"),\n",
    "    (MockAPIError(\"Invalid API key\", 401), \"Auth error 401\"),\n",
    "    (APITimeoutError(request=None), \"Timeout\"),\n",
    "]\n",
    "\n",
    "table = Table(title=\"Error Classification\", show_header=True)\n",
    "table.add_column(\"Error\", style=\"cyan\")\n",
    "table.add_column(\"Class\", style=\"yellow\")\n",
    "table.add_column(\"Action\", style=\"green\")\n",
    "\n",
    "ACTION_MAP = {\n",
    "    ErrorClass.RETRYABLE: \"Wait + retry same model\",\n",
    "    ErrorClass.FAILOVER:  \"Switch to next model in chain\",\n",
    "    ErrorClass.FATAL:     \"Surface error immediately\",\n",
    "}\n",
    "\n",
    "for err, label in mock_errors:\n",
    "    cls = classify_error(err)\n",
    "    table.add_row(label, cls.value, ACTION_MAP[cls])\n",
    "\n",
    "console.print(table)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Part 2: Retry with Exponential Backoff"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def with_retry(\n",
    "    fn: Callable,\n",
    "    max_retries: int = 3,\n",
    "    base_delay: float = 1.0,\n",
    "    max_delay: float = 30.0,\n",
    "    jitter: bool = True,\n",
    ") -> any:\n",
    "    \"\"\"\n",
    "    Retry fn with exponential backoff.\n",
    "    Only retries RETRYABLE errors — fails fast on FATAL/FAILOVER.\n",
    "    \"\"\"\n",
    "    for attempt in range(max_retries + 1):\n",
    "        try:\n",
    "            return fn()\n",
    "        except Exception as e:\n",
    "            cls = classify_error(e)\n",
    "\n",
    "            if attempt == max_retries or cls != ErrorClass.RETRYABLE:\n",
    "                raise\n",
    "\n",
    "            delay = min(base_delay * (2 ** attempt), max_delay)\n",
    "            if jitter:\n",
    "                delay += random.uniform(0, delay * 0.1)\n",
    "\n",
    "            rprint(f\"   ⚠️  Attempt {attempt+1}/{max_retries} failed ({cls.value}). Retry in {delay:.1f}s...\")\n",
    "            time.sleep(delay)\n",
    "\n",
    "\n",
    "# ── Visualize backoff delays ──────────────────────────────────────────────\n",
    "print(\"📊 Exponential backoff delays (base=1s, max=30s, jitter=±10%):\")\n",
    "random.seed(42)\n",
    "for i in range(5):\n",
    "    delay = min(1.0 * (2 ** i), 30.0)\n",
    "    jitter_val = random.uniform(0, delay * 0.1)\n",
    "    total = delay + jitter_val\n",
    "    bar = \"█\" * int(total * 2)\n",
    "    print(f\"   Attempt {i+1}: base={delay:.0f}s + jitter={jitter_val:.2f}s = {total:.2f}s  {bar}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Real model call with retry ──────────────────────────────────────────────\n",
    "\n",
    "def simple_completion(model: str, prompt: str) -> str:\n",
    "    response = client.chat.completions.create(\n",
    "        model=model,\n",
    "        messages=[{\"role\": \"user\", \"content\": prompt}],\n",
    "        max_tokens=100\n",
    "    )\n",
    "    return response.choices[0].message.content\n",
    "\n",
    "\n",
    "# Wrap with retry\n",
    "result = with_retry(\n",
    "    fn=lambda: simple_completion(\"gpt-4o-mini\", \"What is 2+2? Answer in one line.\"),\n",
    "    max_retries=3\n",
    ")\n",
    "print(f\"✅ Result: {result}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Part 3: Circuit Breaker"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class CircuitState(Enum):\n",
    "    CLOSED    = \"CLOSED\"     # Normal — requests flow through\n",
    "    OPEN      = \"OPEN\"       # Provider failing — requests blocked\n",
    "    HALF_OPEN = \"HALF_OPEN\"  # Testing recovery — allow one probe\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class CircuitBreaker:\n",
    "    name: str\n",
    "    failure_threshold: int = 3        # Failures before opening\n",
    "    recovery_timeout: int = 30        # Seconds before half-open probe\n",
    "    success_threshold: int = 2        # Successes needed to close again\n",
    "\n",
    "    state: CircuitState = field(default=CircuitState.CLOSED, init=False)\n",
    "    failure_count: int = field(default=0, init=False)\n",
    "    success_count: int = field(default=0, init=False)\n",
    "    last_failure_time: datetime | None = field(default=None, init=False)\n",
    "\n",
    "    def can_proceed(self) -> bool:\n",
    "        if self.state == CircuitState.CLOSED:\n",
    "            return True\n",
    "        if self.state == CircuitState.OPEN:\n",
    "            if self.last_failure_time and datetime.now() > self.last_failure_time + timedelta(seconds=self.recovery_timeout):\n",
    "                self.state = CircuitState.HALF_OPEN\n",
    "                rprint(f\"   🟡 [{self.name}] Circuit HALF_OPEN — probing...\")\n",
    "                return True\n",
    "            return False\n",
    "        return True  # HALF_OPEN: allow one probe\n",
    "\n",
    "    def record_success(self):\n",
    "        self.failure_count = 0\n",
    "        if self.state == CircuitState.HALF_OPEN:\n",
    "            self.success_count += 1\n",
    "            if self.success_count >= self.success_threshold:\n",
    "                self.state = CircuitState.CLOSED\n",
    "                self.success_count = 0\n",
    "                rprint(f\"   ✅ [{self.name}] Circuit CLOSED — recovered\")\n",
    "\n",
    "    def record_failure(self):\n",
    "        self.failure_count += 1\n",
    "        self.last_failure_time = datetime.now()\n",
    "        if self.failure_count >= self.failure_threshold or self.state == CircuitState.HALF_OPEN:\n",
    "            self.state = CircuitState.OPEN\n",
    "            rprint(f\"   🔴 [{self.name}] Circuit OPEN — {self.failure_count} failures\")\n",
    "\n",
    "    def status(self) -> str:\n",
    "        icons = {CircuitState.CLOSED: \"✅\", CircuitState.OPEN: \"🔴\", CircuitState.HALF_OPEN: \"🟡\"}\n",
    "        return f\"{icons[self.state]} {self.state.value} (failures: {self.failure_count})\"\n",
    "\n",
    "\n",
    "# ── Simulate circuit breaker behavior ─────────────────────────────────────\n",
    "cb = CircuitBreaker(name=\"openai\", failure_threshold=3, recovery_timeout=2)\n",
    "\n",
    "print(\"📊 Simulating circuit breaker transitions:\\n\")\n",
    "print(f\"Initial: {cb.status()}\")\n",
    "\n",
    "# Simulate failures\n",
    "for i in range(3):\n",
    "    cb.record_failure()\n",
    "    print(f\"After failure {i+1}: {cb.status()} | can_proceed={cb.can_proceed()}\")\n",
    "\n",
    "print(f\"\\n   Waiting {cb.recovery_timeout}s for recovery timeout...\")\n",
    "time.sleep(cb.recovery_timeout + 0.1)\n",
    "\n",
    "print(f\"After timeout: can_proceed={cb.can_proceed()} → state is now: {cb.state.value}\")\n",
    "\n",
    "# Simulate recovery\n",
    "cb.record_success()\n",
    "cb.record_success()\n",
    "print(f\"After 2 successes: {cb.status()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Part 4: Full FallbackRouter"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class FallbackResponse:\n",
    "    content: str\n",
    "    model_used: str\n",
    "    fallback_used: bool\n",
    "    attempt_count: int\n",
    "    latency_ms: float\n",
    "    from_cache: bool = False\n",
    "\n",
    "\n",
    "class FallbackRouter:\n",
    "    \"\"\"\n",
    "    Full fallback chain with:\n",
    "    - Per-model circuit breakers\n",
    "    - Retry with exponential backoff for rate limits\n",
    "    - Failover through the chain for outages\n",
    "    - Cache fallback as last resort\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, fallback_chain: list[str]):\n",
    "        self.chain = fallback_chain\n",
    "        self.breakers = {\n",
    "            model: CircuitBreaker(name=model, failure_threshold=3, recovery_timeout=30)\n",
    "            for model in fallback_chain\n",
    "        }\n",
    "        self._cache: dict[str, str] = {}\n",
    "\n",
    "    def _cache_key(self, messages: list[dict]) -> str:\n",
    "        return hashlib.md5(json.dumps(messages, sort_keys=True).encode()).hexdigest()\n",
    "\n",
    "    def _call_model(self, model: str, messages: list[dict]) -> str:\n",
    "        \"\"\"Single model call (overrideable for testing).\"\"\"\n",
    "        response = client.chat.completions.create(\n",
    "            model=model, messages=messages, max_tokens=150\n",
    "        )\n",
    "        return response.choices[0].message.content\n",
    "\n",
    "    def complete(self, messages: list[dict]) -> FallbackResponse:\n",
    "        start = time.time()\n",
    "        attempt = 0\n",
    "        cache_key = self._cache_key(messages)\n",
    "\n",
    "        for i, model in enumerate(self.chain):\n",
    "            breaker = self.breakers[model]\n",
    "\n",
    "            if not breaker.can_proceed():\n",
    "                rprint(f\"   ⚡ [{model}] Circuit OPEN — skipping\")\n",
    "                continue\n",
    "\n",
    "            # Try with retry for rate limits\n",
    "            for retry in range(3):\n",
    "                attempt += 1\n",
    "                try:\n",
    "                    content = self._call_model(model, messages)\n",
    "                    breaker.record_success()\n",
    "\n",
    "                    # Cache on success\n",
    "                    self._cache[cache_key] = content\n",
    "\n",
    "                    return FallbackResponse(\n",
    "                        content=content,\n",
    "                        model_used=model,\n",
    "                        fallback_used=(i > 0),\n",
    "                        attempt_count=attempt,\n",
    "                        latency_ms=round((time.time() - start) * 1000, 1)\n",
    "                    )\n",
    "\n",
    "                except Exception as e:\n",
    "                    cls = classify_error(e)\n",
    "                    rprint(f\"   ❌ [{model}] Attempt {retry+1}: {cls.value} — {type(e).__name__}\")\n",
    "\n",
    "                    if cls == ErrorClass.FATAL:\n",
    "                        raise\n",
    "                    if cls == ErrorClass.FAILOVER:\n",
    "                        breaker.record_failure()\n",
    "                        break  # Move to next model\n",
    "                    if cls == ErrorClass.RETRYABLE:\n",
    "                        if retry < 2:\n",
    "                            delay = min(1.0 * (2 ** retry), 10.0)\n",
    "                            rprint(f\"   ↩️  Retrying in {delay:.1f}s...\")\n",
    "                            time.sleep(delay)\n",
    "                        else:\n",
    "                            breaker.record_failure()\n",
    "                            break\n",
    "\n",
    "        # All models failed — try cache\n",
    "        cached = self._cache.get(cache_key)\n",
    "        if cached:\n",
    "            rprint(\"   📦 Returning cached response\")\n",
    "            return FallbackResponse(\n",
    "                content=cached,\n",
    "                model_used=\"cache\",\n",
    "                fallback_used=True,\n",
    "                attempt_count=attempt,\n",
    "                latency_ms=round((time.time() - start) * 1000, 1),\n",
    "                from_cache=True\n",
    "            )\n",
    "\n",
    "        raise Exception(\"All models in fallback chain failed and no cache available\")\n",
    "\n",
    "\n",
    "print(\"✅ FallbackRouter defined\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build router with fallback chain ──────────────────────────────────────\n",
    "fallback_router = FallbackRouter(fallback_chain=[\n",
    "    \"gpt-4o\",       # Primary\n",
    "    \"gpt-4o-mini\",  # Fallback\n",
    "])\n",
    "\n",
    "messages = [{\"role\": \"user\", \"content\": \"Explain what exponential backoff is in 2 sentences.\"}]\n",
    "\n",
    "print(\"\\n📤 Sending request through FallbackRouter...\\n\")\n",
    "response = fallback_router.complete(messages)\n",
    "\n",
    "rprint(f\"\\n[bold green]✅ Response received[/bold green]\")\n",
    "rprint(f\"   Model: {response.model_used}\")\n",
    "rprint(f\"   Fallback used: {response.fallback_used}\")\n",
    "rprint(f\"   Attempts: {response.attempt_count}\")\n",
    "rprint(f\"   Latency: {response.latency_ms}ms\")\n",
    "rprint(f\"   Content: {response.content[:200]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Part 5: Tenacity — Production-Ready Retry Library"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tenacity import (\n",
    "    retry, stop_after_attempt, wait_exponential_jitter,\n",
    "    retry_if_exception_type, before_sleep_log\n",
    ")\n",
    "import logging\n",
    "\n",
    "logging.basicConfig(level=logging.WARNING)\n",
    "logger = logging.getLogger(__name__)\n",
    "\n",
    "@retry(\n",
    "    retry=retry_if_exception_type(RateLimitError),\n",
    "    wait=wait_exponential_jitter(initial=1, max=30, jitter=2),\n",
    "    stop=stop_after_attempt(4),\n",
    "    before_sleep=before_sleep_log(logger, logging.WARNING)\n",
    ")\n",
    "def resilient_completion(prompt: str, model: str = \"gpt-4o-mini\") -> str:\n",
    "    \"\"\"Completion with automatic retry on rate limit errors.\"\"\"\n",
    "    response = client.chat.completions.create(\n",
    "        model=model,\n",
    "        messages=[{\"role\": \"user\", \"content\": prompt}],\n",
    "        max_tokens=100\n",
    "    )\n",
    "    return response.choices[0].message.content\n",
    "\n",
    "\n",
    "result = resilient_completion(\"What is the fallback pattern in distributed systems?\")\n",
    "print(f\"✅ Tenacity result: {result[:200]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Summary\n",
    "\n",
    "| Component | Handles |\n",
    "|---|---|\n",
    "| `classify_error()` | Determines correct recovery strategy |\n",
    "| `with_retry()` | Exponential backoff for rate limits (429) |\n",
    "| `CircuitBreaker` | Stops hammering degraded providers |\n",
    "| `FallbackRouter` | Chains all strategies together end-to-end |\n",
    "| `tenacity` | Production-grade retry with one decorator |\n",
    "\n",
    "**Next:** `05_load_balancing` — distributing load across multiple keys and providers."
   ]
  }
