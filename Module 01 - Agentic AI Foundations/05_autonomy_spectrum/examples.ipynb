   "source": [
    "# 05 — The Autonomy Spectrum (Code Examples)\n",
    "\n",
    "Implement different autonomy levels and demonstrate HITL patterns.\n",
    "\n",
    "**Prerequisites:** `pip install openai python-dotenv rich`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, json, time\n",
    "from dataclasses import dataclass\n",
    "from enum import Enum\n",
    "from dotenv import load_dotenv\n",
    "from openai import OpenAI\n",
    "from rich import print as rprint\n",
    "from rich.panel import Panel\n",
    "\n",
    "load_dotenv()\n",
    "client = OpenAI(api_key=os.getenv('OPENAI_API_KEY'))\n",
    "print('Setup complete')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Autonomy Levels as a Class Hierarchy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class AutonomyLevel(Enum):\n",
    "    L0_NO_AI          = 0  # Human does everything\n",
    "    L1_SUGGEST_ONLY   = 1  # AI suggests, human decides\n",
    "    L2_DRAFT_REVIEW   = 2  # AI drafts, human reviews before action\n",
    "    L3_AUTO_NOTIFY    = 3  # AI acts, notifies human\n",
    "    L4_AUTO_AUDIT     = 4  # AI acts, logs for periodic review\n",
    "    L5_FULL_AUTONOMY  = 5  # No human oversight\n",
    "\n",
    "@dataclass\n",
    "class AgentAction:\n",
    "    name: str\n",
    "    description: str\n",
    "    is_reversible: bool\n",
    "    risk_level: str  # low / medium / high\n",
    "    recommended_level: AutonomyLevel\n",
    "\n",
    "# Define some example actions with their recommended autonomy levels\n",
    "EXAMPLE_ACTIONS = [\n",
    "    AgentAction(\"summarize_email\",   \"Summarize incoming emails\",                   True,  \"low\",    AutonomyLevel.L4_AUTO_AUDIT),\n",
    "    AgentAction(\"draft_reply\",       \"Draft an email reply\",                        True,  \"low\",    AutonomyLevel.L2_DRAFT_REVIEW),\n",
    "    AgentAction(\"send_email\",        \"Send email to customer\",                      False, \"medium\", AutonomyLevel.L2_DRAFT_REVIEW),\n",
    "    AgentAction(\"book_meeting\",      \"Schedule calendar event\",                     True,  \"medium\", AutonomyLevel.L3_AUTO_NOTIFY),\n",
    "    AgentAction(\"execute_payment\",   \"Process a financial transaction\",              False, \"high\",   AutonomyLevel.L1_SUGGEST_ONLY),\n",
    "    AgentAction(\"delete_records\",    \"Delete database records\",                     False, \"high\",   AutonomyLevel.L1_SUGGEST_ONLY),\n",
    "    AgentAction(\"tag_ticket\",        \"Auto-tag support tickets by category\",        True,  \"low\",    AutonomyLevel.L4_AUTO_AUDIT),\n",
    "]\n",
    "\n",
    "print(\"Action Risk Analysis:\")\n",
    "print(f\"{'Action':<25} {'Reversible':<12} {'Risk':<10} {'Recommended Level':<25}\")\n",
    "print(\"-\" * 72)\n",
    "for action in EXAMPLE_ACTIONS:\n",
    "    rev = '✅' if action.is_reversible else '❌'\n",
    "    print(f\"{action.name:<25} {rev:<12} {action.risk_level:<10} {action.recommended_level.name}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Autonomy Level Classifier — Recommends the Right Level"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def classify_autonomy_level(action_description: str, success_rate: float = None) -> dict:\n",
    "    \"\"\"\n",
    "    Uses an LLM to recommend the appropriate autonomy level\n",
    "    based on the action's characteristics.\n",
    "    \"\"\"\n",
    "    sr_context = f\"Current agent success rate for this task: {success_rate:.0%}.\" if success_rate else \"\"\n",
    "    \n",
    "    response = client.chat.completions.create(\n",
    "        model=\"gpt-4o-mini\",\n",
    "        messages=[{\"role\": \"user\", \"content\":\n",
    "            f\"Action: {action_description}\\n{sr_context}\\n\\n\"\n",
    "            \"Analyze this action and recommend an autonomy level (0-5):\\n\"\n",
    "            \"0=No AI, 1=Suggest only, 2=Draft+Review, 3=Auto+Notify, 4=Auto+Audit, 5=Full autonomy\\n\\n\"\n",
    "            \"Consider: reversibility, risk level, frequency, regulatory requirements.\\n\"\n",
    "            \"Return JSON: {\\\"level\\\": 0-5, \\\"reasoning\\\": \\\"short explanation\\\", \\\"hitl_mechanism\\\": \\\"description\\\"}\\n\"\n",
    "            \"Return ONLY valid JSON.\"\n",
    "        }]\n",
    "    ).choices[0].message.content\n",
    "    \n",
    "    try:\n",
    "        if '```' in response:\n",
    "            response = response.split('```')[1].replace('json', '').strip()\n",
    "        return json.loads(response)\n",
    "    except:\n",
    "        return {\"level\": 2, \"reasoning\": \"Parse error — defaulting to safe level\", \"hitl_mechanism\": \"Manual review\"}\n",
    "\n",
    "actions_to_classify = [\n",
    "    (\"Automatically tag and categorize incoming support emails with topic labels\", 0.97),\n",
    "    (\"Send email responses to unhappy customers with refund offers\", 0.82),\n",
    "    (\"Execute cryptocurrency trades worth $50,000 based on market signals\", None),\n",
    "    (\"Update patient medication dosage in healthcare records\", None),\n",
    "]\n",
    "\n",
    "print(\"AUTONOMY LEVEL CLASSIFIER\")\n",
    "print(\"=\" * 65)\n",
    "for action, success_rate in actions_to_classify:\n",
    "    result = classify_autonomy_level(action, success_rate)\n",
    "    level_name = AutonomyLevel(result.get('level', 2)).name\n",
    "    print(f\"\\nAction: {action[:60]}\")\n",
    "    print(f\"  Recommended: Level {result.get('level')} ({level_name})\")\n",
    "    print(f\"  Reasoning: {result.get('reasoning', 'N/A')[:80]}\")\n",
    "    print(f\"  HITL: {result.get('hitl_mechanism', 'N/A')[:80]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## HITL Pattern 1: Approval Gate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ApprovalGateAgent:\n",
    "    \"\"\"\n",
    "    HITL Pattern: Approval Gate\n",
    "    Agent plans and drafts, PAUSES for human approval, then executes.\n",
    "    Use for: emails, financial transactions, external API calls.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, auto_approve: bool = False):\n",
    "        self.auto_approve = auto_approve  # True = simulates human approval\n",
    "        self.audit_log = []\n",
    "    \n",
    "    def generate_action(self, task: str) -> dict:\n",
    "        \"\"\"Agent drafts what it wants to do.\"\"\"\n",
    "        response = client.chat.completions.create(\n",
    "            model=\"gpt-4o-mini\",\n",
    "            messages=[{\n",
    "                \"role\": \"system\",\n",
    "                \"content\": \"You are an agent that drafts actions. Present your proposed action clearly.\"\n",
    "            }, {\"role\": \"user\", \"content\": task}]\n",
    "        ).choices[0].message.content\n",
    "        \n",
    "        return {\n",
    "            \"proposed_action\": response,\n",
    "            \"task\": task,\n",
    "            \"status\": \"pending_approval\"\n",
    "        }\n",
    "    \n",
    "    def request_approval(self, action: dict) -> bool:\n",
    "        \"\"\"HITL checkpoint: pause and request human approval.\"\"\"\n",
    "        print(\"\\n\" + \"⚠️ \" * 20)\n",
    "        print(\"HUMAN APPROVAL REQUIRED\")\n",
    "        print(\"⚠️ \" * 20)\n",
    "        print(f\"\\nProposed Action:\\n{action['proposed_action']}\")\n",
    "        print()\n",
    "        \n",
    "        if self.auto_approve:\n",
    "            print(\"[AUTO-APPROVE MODE: Simulating human approved]\")\n",
    "            return True\n",
    "        else:\n",
    "            user_input = input(\"Approve this action? (yes/no): \").lower().strip()\n",
    "            return user_input in ('yes', 'y')\n",
    "    \n",
    "    def execute_action(self, action: dict) -> str:\n",
    "        \"\"\"Execute the approved action.\"\"\"\n",
    "        result = f\"✅ Executed: {action['proposed_action'][:80]}...\"\n",
    "        self.audit_log.append({\n",
    "            \"task\": action[\"task\"],\n",
    "            \"action\": action[\"proposed_action\"][:100],\n",
    "            \"approved\": True,\n",
    "            \"timestamp\": time.strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "        })\n",
    "        return result\n",
    "    \n",
    "    def run(self, task: str) -> str:\n",
    "        \"\"\"Full approval gate flow: draft → pause → approved? → execute.\"\"\"\n",
    "        print(f\"Task: {task}\")\n",
    "        \n",
    "        # Step 1: Agent drafts action\n",
    "        action = self.generate_action(task)\n",
    "        \n",
    "        # Step 2: PAUSE for human approval (the HITL gate)\n",
    "        approved = self.request_approval(action)\n",
    "        \n",
    "        if approved:\n",
    "            result = self.execute_action(action)\n",
    "            print(f\"Result: {result}\")\n",
    "            return result\n",
    "        else:\n",
    "            print(\"Action REJECTED by human. No action taken.\")\n",
    "            self.audit_log.append({\"task\": task, \"approved\": False, \"timestamp\": time.strftime(\"%Y-%m-%d %H:%M:%S\")})\n",
    "            return \"Action rejected.\"\n",
    "\n",
    "# Demo approval gate (auto_approve=True for notebook demo)\n",
    "agent = ApprovalGateAgent(auto_approve=True)\n",
    "agent.run(\"Send a refund email to customer john@example.com for order #12345 confirming $89.99 refund\")\n",
    "\n",
    "print(f\"\\nAudit log: {len(agent.audit_log)} entries\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## HITL Pattern 2: Interrupt on Uncertainty"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def confidence_evaluator(context: str, proposed_action: str) -> float:\n",
    "    \"\"\"Rate confidence 0.0-1.0 for proceeding with an action.\"\"\"\n",
    "    response = client.chat.completions.create(\n",
    "        model=\"gpt-4o-mini\",\n",
    "        messages=[{\"role\": \"user\", \"content\":\n",
    "            f\"Context: {context}\\nProposed action: {proposed_action}\\n\\n\"\n",
    "            \"Rate confidence 0.0-1.0 that this action is correct and safe.\\n\"\n",
    "            \"Consider: ambiguity, risk, missing info, irreversibility.\\n\"\n",
    "            \"Return ONLY a number like: 0.85\"\n",
    "        }]\n",
    "    ).choices[0].message.content.strip()\n",
    "    \n",
    "    try:\n",
    "        return float(response)\n",
    "    except:\n",
    "        return 0.5\n",
    "\n",
    "class UncertaintyInterruptAgent:\n",
    "    \"\"\"Runs autonomously but interrupts + asks when confidence is low.\"\"\"\n",
    "    \n",
    "    def __init__(self, confidence_threshold: float = 0.75, auto_clarify: bool = True):\n",
    "        self.threshold = confidence_threshold\n",
    "        self.auto_clarify = auto_clarify\n",
    "    \n",
    "    def process(self, task: str, context: str = \"\") -> str:\n",
    "        print(f\"Task: {task}\")\n",
    "        \n",
    "        # Agent drafts an action\n",
    "        proposed = client.chat.completions.create(\n",
    "            model=\"gpt-4o-mini\",\n",
    "            messages=[\n",
    "                {\"role\": \"system\", \"content\": f\"You are an autonomous agent. Context: {context}\"},\n",
    "                {\"role\": \"user\",   \"content\": f\"Propose action for: {task}\"}\n",
    "            ]\n",
    "        ).choices[0].message.content\n",
    "        \n",
    "        # Check confidence\n",
    "        confidence = confidence_evaluator(f\"{context}. Task: {task}\", proposed)\n",
    "        print(f\"Proposed: {proposed[:100]}\")\n",
    "        print(f\"Confidence: {confidence:.2f} (threshold: {self.threshold})\")\n",
    "        \n",
    "        if confidence >= self.threshold:\n",
    "            print(\"✅ Confidence OK — proceeding autonomously\")\n",
    "            return f\"Executed: {proposed[:80]}\"\n",
    "        else:\n",
    "            print(\"⚠️  Low confidence — INTERRUPTED for human clarification\")\n",
    "            if self.auto_clarify:\n",
    "                clarification = \"[Auto-clarification: User said 'proceed with caution']\"\n",
    "            else:\n",
    "                clarification = input(\"Please clarify: \")\n",
    "            print(f\"Clarification received: {clarification}\")\n",
    "            return f\"Executed with clarification: {proposed[:60]}\"\n",
    "\n",
    "agent = UncertaintyInterruptAgent(confidence_threshold=0.8, auto_clarify=True)\n",
    "print(\"=\" * 55)\n",
    "# High-confidence case\n",
    "agent.process(\"Count the words in this sentence: 'Hello world, I love AI'\", context=\"Text processing task\")\n",
    "print()\n",
    "# Low-confidence case (ambiguous)\n",
    "agent.process(\"Delete all old data\", context=\"User said to clean up, didn't specify which data\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Utility: Recommend Autonomy Level Dynamically"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from rich.table import Table\n",
    "\n",
    "# Summary: when to use which HITL pattern\n",
    "table = Table(title=\"HITL Patterns — Quick Reference\")\n",
    "table.add_column(\"Pattern\",          style=\"bold cyan\", width=25)\n",
    "table.add_column(\"Mechanism\",        width=30)\n",
    "table.add_column(\"Best For\",         width=30)\n",
    "table.add_column(\"Autonomy Level\",   width=15)\n",
    "\n",
    "for row in [\n",
    "    (\"Approval Gate\",         \"Pause → Human approves → Execute\",      \"Emails, payments, deployments\",  \"Level 2\"),\n",
    "    (\"Review Before Publish\", \"Draft → Human edits → Human triggers\",  \"Content, reports, proposals\",    \"Level 2\"),\n",
    "    (\"Interrupt on Doubt\",    \"Run → Uncertain? Alert → Clarify\",       \"Complex, ambiguous tasks\",       \"Level 3\"),\n",
    "    (\"Post-Hoc Audit\",        \"Act → Log → Human reviews weekly\",       \"Low-risk, high-volume tasks\",    \"Level 4\"),\n",
    "    (\"Notification Only\",     \"Act → Notify → No review needed\",        \"Reversible, well-tested tasks\",  \"Level 3\"),\n",
    "]:\n",
    "    table.add_row(*row)\n",
    "\n",
    "rprint(table)"
   ]
  }
